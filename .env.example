OPENROUTER_API_KEY=replace_me
OPENROUTER_MODEL=openai/gpt-4o-mini

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_USERNAME=@your_channel_username

# One or many RSS sources (comma or newline separated)
RSS_URLS=https://www.reddit.com/r/technology/.rss
# RSS_URL is supported for backward compatibility
RSS_URL=
POLL_INTERVAL_SECONDS=300
DB_PATH=./rssbot.sqlite3
LOG_LEVEL=DEBUG
LOG_FILE=./rssbot.log

# Cron schedule(s) for posting (5-field cron). Comma/newline separated.
# Example: "0 9 * * *" (every day at 09:00)
CRON_SCHEDULES=0 */6 * * *

# Optional: limit posting volume per poll
MAX_ITEMS_PER_POLL=5

# Optional: summary formatting
SUMMARY_MAX_CHARS=420
TRANSLATE_SUMMARY=1

# Optional: add attribution footer to Telegram message
ADD_SOURCE_LINK=1
